# ==============================================================================
# QFlow — Environment Variables Configuration Template
# ==============================================================================

# FastAPI Configuration
PROJECT_NAME=QFlow
API_V1_STR=/api/v1

# --- DATABASE CONFIGURATION (SUPABASE POSTGRESQL) ---
# Paste your Supabase Database connection strings here.
# Note: For Async connections, use the 'asyncpg' driver prefix.

# Transaction Pooler (Port 6543) or Direct Connection (Port 5432)
# Async URL used by FastAPI app (with asyncpg driver)
DATABASE_URL=postgresql://postgres:AjabY2tcuqXJ1z6M@db.yjuvbzyzhqtnzdhmboyq.supabase.co:5432/postgres

# Direct connection used by Alembic migrations (with sync driver)
SYNC_DATABASE_URL=postgresql://postgres.yjuvbzyzhqtnzdhmboyq:AjabY2tcuqXJ1z6M@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres

# --- SECURITY CONFIGURATION ---
# Generate strong 32-byte keys for production (e.g., using `openssl rand -hex 32`)
JWT_SECRET_KEY=qflow_development_secret_access_jwt_key_32_bytes_long
JWT_REFRESH_SECRET_KEY=qflow_development_secret_refresh_jwt_key_32_bytes_long
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- SMTP MAIL CONFIGURATION (Optional - falls back to console logging if empty) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@qflow.com
